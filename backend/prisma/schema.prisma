// Schema do Lasanharia.
// Decisão: valores monetários são Int em centavos. Ver CLAUDE.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model StoreConfig {
  id              Int      @id @default(autoincrement())
  storeName       String
  whatsappNumber  String
  address         String
  // Cidade e UF da loja — usados para complementar o "Ver rota" do admin.
  city            String   @default("")
  state           String   @default("")
  isOpen          Boolean  @default(true)
  preparationTime String
  announcement    String?
  // Frete único da loja, em centavos. 0 = grátis. Editável via admin/Prisma Studio.
  deliveryFee     Int      @default(0)
  // Chave PIX da loja — entra na mensagem "Avisar cliente" quando pedido for Pix+Confirmado.
  pixKey          String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  sortOrder Int       @default(0)
  active    Boolean   @default(true)
  products  Product[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price       Int
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
  imageUrl    String?
  available   Boolean  @default(true)
  featured    Boolean  @default(false)
  // Programa de Fidelidade (ver CLAUDE.md): se true, cada unidade vendida deste produto
  // vale 1 ponto no crédito (na entrega). Marcado caso a caso, NÃO por categoria.
  countsForLoyalty Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
}

model Order {
  id            Int         @id @default(autoincrement())
  orderNumber   Int         @unique
  customerName  String
  customerPhone String
  orderType     String
  address       String?
  addressNumber String?
  neighborhood  String?
  reference     String?
  notes         String?
  paymentMethod String
  changeFor     Int?
  subtotal      Int
  deliveryFee   Int         @default(0)
  // Desconto aplicado no total (centavos). Hoje só usado pelo resgate de fidelidade:
  // = preço de UMA lasanha quando isRedemption=true. Snapshot — não recalcular do preço atual.
  discountAmount Int        @default(0)
  total         Int
  status        String      @default("Pendente")
  items         OrderItem[]

  // Programa de Fidelidade (ver CLAUDE.md).
  //   loyaltyCustomerId — null se o pedido não está vinculado ao programa.
  //   isRedemption      — true se este pedido usa o resgate de "lasanha grátis".
  //   pointsEarned      — quantos pontos este pedido creditou ao saldo do cliente.
  //                       Preenchido na transição para "Entregue". Serve como trava
  //                       de idempotência: > 0 significa "já creditou, não crédite de novo".
  loyaltyCustomerId Int?
  loyaltyCustomer   LoyaltyCustomer? @relation(fields: [loyaltyCustomerId], references: [id], onDelete: SetNull)
  isRedemption      Boolean          @default(false)
  pointsEarned      Int              @default(0)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([loyaltyCustomerId])
}

model OrderItem {
  id          Int    @id @default(autoincrement())
  orderId     Int
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   Int
  productName String
  quantity    Int
  unitPrice   Int
  totalPrice  Int

  @@index([orderId])
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

// Programa de Fidelidade (ver CLAUDE.md). Cliente identificado pelo telefone,
// sem senha. points = saldo atual (sobe com crédito, desce com resgate/estorno).
// totalEarned = histórico bruto acumulado, NUNCA decrementa.
model LoyaltyCustomer {
  id          Int      @id @default(autoincrement())
  phone       String   @unique
  name        String
  points      Int      @default(0)
  totalEarned Int      @default(0)
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
