# Copie este arquivo para .env e ajuste os valores. NUNCA commite o .env.

# Banco SQLite local (arquivo gerado em backend/prisma/dev.db)
DATABASE_URL="file:./dev.db"

# Segredo para assinar JWT do painel admin (Fase 3). Gere algo longo e único.
# Exemplo: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="troque-este-valor-antes-de-subir"

# Número do WhatsApp que recebe os pedidos (formato internacional, só dígitos).
# Ex.: 5511999999999 (55 = Brasil, 11 = DDD, 9 + 8 dígitos)
STORE_WHATSAPP_NUMBER="5511999999999"

# Porta do backend Express (Fase 2 em diante)
PORT=3000
